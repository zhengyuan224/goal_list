{
  "name": "goal-tracker-widget",
  "version": "1.0.0",
  "description": "A premium Electron desktop widget for goal and task tracking",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "keywords": [
    "electron",
    "goal-tracker",
    "desktop-widget"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.goaltracker.widget",
    "productName": "Goal Tracker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "electron-store": "^7.0.3"
  }
}
